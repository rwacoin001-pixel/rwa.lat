# Copy this file to deploy/production.env on the deployment host or inject the
# same names from a Secret Manager. Never commit the populated file.
APP_ENV=production
NODE_ENV=production
PRODUCTION_DATABASE_URL=
ADMIN_DATABASE_URL=
DATABASE_POOL_MAX=5
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
API_HOST_PORT=4000
ADMIN_HOST_PORT=4100

PUBLIC_API_URL=https://api.example.com
PUBLIC_APP_URL=https://app.example.com
PUBLIC_ADMIN_API_URL=https://admin-api.example.com
CORS_ORIGINS=https://app.example.com
ADMIN_CORS_ORIGINS=https://admin.example.com
TRUST_PROXY_HOPS=1
PASSKEY_RP_ID=example.com
PASSKEY_ORIGIN=https://app.example.com
PASSKEY_RP_NAME=RWA.LAT

# Inject all values below from Secret Manager.
IDENTITY_HMAC_KEY=
# Use IDENTITY_ENC_KEY for initial single-key deployment, or use the two
# versioned variables for zero-downtime rotation. Do not populate both paths.
IDENTITY_ENC_KEY=
IDENTITY_ENC_KEYS_JSON=
IDENTITY_ACTIVE_KEY_VERSION=
METRICS_BEARER_TOKEN=
ADMIN_MFA_ENCRYPTION_KEY=
ADMIN_MFA_KEYS_JSON=
ADMIN_MFA_ACTIVE_KEY_VERSION=
WALLET_WEBHOOK_SECRET=

AUTH_ADAPTER=production
EMAIL_PROVIDER=smtp
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=RWA.LAT
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_AUTH_MODE=plain
SMTP_USER=
SMTP_PASSWORD=
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://app.example.com/auth/callback/google
X_OAUTH_ENABLED=false
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
X_OAUTH_REDIRECT_URI=https://app.example.com/auth/callback/x
OAUTH_HTTP_TIMEOUT_MS=10000
ADMIN_MFA_REQUIRED=true

# Safe first production deployment: architecture enabled, money movement locked.
PRODUCTION_FINANCIAL_FEATURES_ENABLED=false
WALLET_EXECUTION_ENABLED=false
WALLET_EXECUTION_WORKER_ENABLED=false
POLYMARKET_TRADING_ENABLED=false
DEMO_OPERATIONS_ENABLED=false
DEMO_WALLET_CREDIT_ENABLED=false

# Set these only after concrete live adapters are installed and rehearsed.
KYC_PROVIDER=
SANCTIONS_PROVIDER=
WALLET_CUSTODY_ADAPTER=
ALLOWED_REGIONS=
WITHDRAWAL_ADDRESS_COOLDOWN_SECONDS=86400
WITHDRAWAL_NEW_DEVICE_COOLDOWN_SECONDS=86400
WITHDRAWAL_PER_TRANSACTION_LIMIT_ATOMIC=
WITHDRAWAL_DAILY_LIMIT_ATOMIC=
WITHDRAWAL_ADMIN_APPROVALS_REQUIRED=2
WITHDRAWAL_EXECUTION_LEASE_SECONDS=120
WALLET_EXECUTION_QUEUE_LEASE_SECONDS=300
WALLET_EXECUTION_WORKER_POLL_MS=5000
FINANCIAL_RELEASE_CHANGE_ID=

# Object storage can remain locked for the first deployment.
OBJECT_STORAGE_ENABLED=false
S3_REGION=
S3_ENDPOINT=
S3_AUTH_MODE=workload
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_KMS_KEY_ID=
S3_FORCE_PATH_STYLE=false
S3_BUCKET_MAP_JSON={"rwa-kyc":"replace-prod-kyc","rwa-assets":"replace-prod-assets","rwa-attachments":"replace-prod-attachments"}
OBJECT_STORAGE_SCAN_PROVIDER=
OBJECT_STORAGE_SCAN_CALLBACK_SECRET=
