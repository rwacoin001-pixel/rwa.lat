# Copy these names into the deployment platform or Secret Manager. Never
# commit a populated production.env file.
APP_ENV=production
NODE_ENV=production

# PostgreSQL 16+; both URLs must use TLS and a database ending in _production.
PRODUCTION_DATABASE_URL=
ADMIN_DATABASE_URL=
DATABASE_POOL_MAX=5
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
API_HOST_PORT=4000
ADMIN_HOST_PORT=4100

# Public origins. The confirmed frontend domain is rwa.lat.
PUBLIC_API_URL=https://api.rwa.lat
PUBLIC_APP_URL=https://rwa.lat
PUBLIC_ADMIN_API_URL=https://admin-api.rwa.lat
CORS_ORIGINS=https://rwa.lat
ADMIN_CORS_ORIGINS=https://admin.rwa.lat
# Set this only after counting the real CDN/load-balancer hops.
TRUST_PROXY_HOPS=1
PASSKEY_RP_ID=rwa.lat
PASSKEY_ORIGIN=https://rwa.lat
PASSKEY_RP_NAME=RWA.LAT

# Inject independent values from Secret Manager. Do not reuse any key.
IDENTITY_HMAC_KEY=
# Choose either the single-key variables or the versioned rotation variables.
IDENTITY_ENC_KEY=
IDENTITY_ENC_KEYS_JSON=
IDENTITY_ACTIVE_KEY_VERSION=
METRICS_BEARER_TOKEN=
ADMIN_MFA_ENCRYPTION_KEY=
ADMIN_MFA_KEYS_JSON=
ADMIN_MFA_ACTIVE_KEY_VERSION=
ADMIN_MFA_REQUIRED=true
WALLET_WEBHOOK_SECRET=

AUTH_ADAPTER=production
# Resend uses HTTPS and works on platforms that block outbound SMTP ports.
EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@rwa.lat
EMAIL_FROM_NAME=RWA.LAT
RESEND_API_KEY=
RESEND_HTTP_TIMEOUT_MS=10000
# SMTP remains supported for hosts that allow outbound mail connections.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_AUTH_MODE=plain
SMTP_USER=
SMTP_PASSWORD=
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000

# Google can be enabled after the production client secret is stored. X stays
# disabled while the X account/application is suspended or unapproved.
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://rwa.lat/auth/callback/google
X_OAUTH_ENABLED=false
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
X_OAUTH_REDIRECT_URI=https://rwa.lat/auth/callback/x
OAUTH_HTTP_TIMEOUT_MS=10000

# Safe first production deployment: real auth/runtime, all money movement off.
PRODUCTION_FINANCIAL_FEATURES_ENABLED=false
WALLET_EXECUTION_ENABLED=false
WALLET_EXECUTION_WORKER_ENABLED=false
POLYMARKET_TRADING_ENABLED=false
DEMO_OPERATIONS_ENABLED=false
DEMO_WALLET_CREDIT_ENABLED=false

# KYC can be enabled independently for sandbox/production onboarding. Keep
# KYC_PROVIDER=stub until the Didit console values below are configured.
KYC_PROVIDER=stub
DIDIT_API_BASE_URL=https://verification.didit.me
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
DIDIT_WEBHOOK_SECRET=
DIDIT_CALLBACK_URL=https://rwa.lat/profile/kyc?status=complete
DIDIT_API_TIMEOUT_MS=10000
DIDIT_API_MAX_RETRIES=2
DIDIT_API_RETRY_BASE_DELAY_MS=500
# Configure the Didit destination itself as:
# https://api.rwa.lat/v1/compliance/kyc/webhooks/didit

# These remain stubbed. Therefore the application capability guard still
# refuses PRODUCTION_FINANCIAL_FEATURES_ENABLED=true.
SANCTIONS_PROVIDER=stub
WALLET_CUSTODY_ADAPTER=stub
ALLOWED_REGIONS=
WITHDRAWAL_ADDRESS_COOLDOWN_SECONDS=86400
WITHDRAWAL_NEW_DEVICE_COOLDOWN_SECONDS=86400
WITHDRAWAL_PER_TRANSACTION_LIMIT_ATOMIC=
WITHDRAWAL_DAILY_LIMIT_ATOMIC=
WITHDRAWAL_ADMIN_APPROVALS_REQUIRED=2
WITHDRAWAL_EXECUTION_LEASE_SECONDS=120
WALLET_EXECUTION_QUEUE_LEASE_SECONDS=300
WALLET_EXECUTION_WORKER_POLL_MS=5000
FINANCIAL_RELEASE_CHANGE_ID=

# Object storage remains locked until KMS and malware scanning are rehearsed.
OBJECT_STORAGE_ENABLED=false
S3_REGION=
S3_ENDPOINT=
S3_AUTH_MODE=workload
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_KMS_KEY_ID=
S3_FORCE_PATH_STYLE=false
S3_BUCKET_MAP_JSON={"rwa-kyc":"replace-prod-kyc","rwa-assets":"replace-prod-assets","rwa-attachments":"replace-prod-attachments"}
OBJECT_STORAGE_SCAN_PROVIDER=
OBJECT_STORAGE_SCAN_CALLBACK_SECRET=

# Each partner must receive a distinct 32+ character secret.
PARTNER_CALLBACK_SECRETS_JSON=

# Optional telemetry exports.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=rwa-lat-core
LOG_LEVEL=info
