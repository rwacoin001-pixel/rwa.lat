PORT=4100
APP_ENV=development
ADMIN_DATABASE_URL=postgresql://rwa:***@localhost:5432/rwa_lat_dev
ADMIN_CORS_ORIGINS=http://localhost:3100
PUBLIC_ADMIN_API_URL=http://localhost:4100
TRUST_PROXY_HOPS=0
# Server-side, revocable admin-session policy. Password hashes are provisioned
# out of band; no bootstrap password or API key belongs in this file.
ADMIN_SESSION_TTL_SECONDS=28800
ADMIN_LOGIN_MAX_FAILURES=5
ADMIN_LOGIN_LOCK_SECONDS=900
ADMIN_MFA_REQUIRED=false
# Required only after an administrator MFA factor is enabled. Generate and store
# a 32-byte base64 key in the secret manager; never expose it to the browser.
ADMIN_MFA_ENCRYPTION_KEY=
# Optional rotation path. New MFA ciphertext should use the active version;
# keep prior versions until every stored secret has been re-encrypted.
ADMIN_MFA_KEYS_JSON=
ADMIN_MFA_ACTIVE_KEY_VERSION=
