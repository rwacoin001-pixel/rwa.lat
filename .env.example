# Server-only configuration. Do not expose these values with NEXT_PUBLIC_ prefixes.
POLYMARKET_RELAYER_API_KEY=
POLYMARKET_RELAYER_API_KEY_ADDRESS=
POLYMARKET_BUILDER_ADDRESS=
POLYMARKET_BUILDER_CODE=
POLYMARKET_READ_ENABLED=true
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_TRADING_ENABLED=false

# API-only wallet controls. Real execution remains off until a live custody adapter is installed.
WALLET_EXECUTION_ENABLED=false
WALLET_WEBHOOK_SECRET=

# H5 → Core API base URL (single source of truth for all pages)
NEXT_PUBLIC_API_URL=http://localhost:4000
